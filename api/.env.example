# Airtable
AIRTABLE_API_KEY=your_api_key_here
AIRTABLE_BASE_ID=your_base_id_here
AIRTABLE_TABLE_NAME=experiment_queue

# Google Calendar (optional)
GOOGLE_EXPERIMENT_CALENDAR_ID=
GOOGLE_TECH_CALENDAR_ID=
# Local dev: path to service account JSON file
GOOGLE_SERVICE_ACCOUNT_FILE=service-account-credentials.json
# Production (ECS): not needed — loaded from Secrets Manager via
# GOOGLE_SERVICE_ACCOUNT_JSON key in the secret

# AWS
AWS_REGION=us-west-2

# Secrets Manager (production only — leave blank for local dev)
# When set, secrets are fetched from this Secrets Manager secret at startup.
# The secret should be a JSON object with these keys:
#   AIRTABLE_API_KEY, AIRTABLE_BASE_ID,
#   GOOGLE_EXPERIMENT_CALENDAR_ID, GOOGLE_TECH_CALENDAR_ID,
#   GOOGLE_SERVICE_ACCOUNT_JSON (full JSON string of the service account)
AWS_SECRET_NAME=

# Logging
LOG_LEVEL=INFO
